<!DOCTYPE html>
<html>
  <head>
    <title>ONDC Demo</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <!-- Logo + Welcome message container -->
      <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 1rem; background-color: #BFDC00;">
        <img src="https://ondc.org/assets/theme/images/ondc_registered_logo.svg?v=93be4eb19d" alt="ONDC Logo" style="height: 40px;" />
        <div style="font-weight: bold; font-size: 1.25rem; color: #333;">
          Empowering India’s Digital Commerce Ecosystem
        </div>
      </div>

      <nav style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; border-bottom: 1px solid #ccc;">
        <div style="display: flex; gap: 1rem;">
          <%= link_to root_path, style: "background-color: #bfdbfe; padding: 0.5rem 1rem; border-radius: 0.5rem; color: #1e40af; font-weight: 600; text-decoration: none;" do %>
            Home
          <% end %>

          <%= link_to products_path, style: "background-color: #bbf7d0; padding: 0.5rem 1rem; border-radius: 0.5rem; color: #166534; font-weight: 600; text-decoration: none;" do %>
            Products
          <% end %>

          <%= link_to cart_path, style: "background-color: #fde68a; padding: 0.5rem 1rem; border-radius: 0.5rem; color: #92400e; font-weight: 600; text-decoration: none;" do %>
            Cart
          <% end %>
        </div>

        <!-- Search form with icon -->
        <%= form_with url: products_path, method: :get, local: true, style: "display: flex; align-items: center; background-color: #e0e7ff; border-radius: 0.5rem; padding: 0.25rem 0.5rem; margin-right: 1rem;" do %>
          <%= text_field_tag :query, params[:query], placeholder: "Search", style: "border: none; outline: none; background: transparent; padding: 0.25rem; font-size: 1rem; width: 120px;" %>
          <button type="submit" style="background: none; border: none; padding: 0; cursor: pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" style="width: 20px; height: 20px; color: #4338ca;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1116.65 16.65z" />
            </svg>
          </button>
        <% end %>

        <!-- User login part -->
        <div style="display: flex; align-items: center; gap: 0.75rem; background-color: #bfdbfe; padding: 0.4rem 1rem; border-radius: 9999px; font-weight: 600; color: #1e40af;">
          <% if user_signed_in? %>
            <!-- User icon -->
            <svg xmlns="http://www.w3.org/2000/svg" style="width: 20px; height: 20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A12 12 0 0112 15c2.982 0 5.73 1.117 7.879 2.804M12 12a4 4 0 100-8 4 4 0 000 8z" />
            </svg>
            <span>Hello, <%= current_user.email %></span>
            <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete, confirm: "Are you sure?" },
                        style: "background-color: #ef4444; color: white; padding: 0.3rem 0.7rem; border-radius: 0.375rem; font-weight: 600; text-decoration: none; transition: background-color 0.3s;",
                        onmouseover: "this.style.backgroundColor='#b91c1c'",
                        onmouseout: "this.style.backgroundColor='#ef4444'" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path,
                        style: "background-color: #3b82f6; color: white; padding: 0.4rem 0.9rem; border-radius: 0.375rem; font-weight: 600; text-decoration: none; transition: background-color 0.3s;",
                        onmouseover: "this.style.backgroundColor='#2563eb'",
                        onmouseout: "this.style.backgroundColor='#3b82f6'" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main style="padding: 1rem;">
      <%= yield %>
    </main>
  </body>
</html>
